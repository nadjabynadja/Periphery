# Required
ANTHROPIC_API_KEY=sk-ant-...

# Required for map display
VITE_MAPBOX_ACCESS_TOKEN=pk.ey...

# Optional — enables real-time external search on queries
EXA_API_KEY=

# Optional — Photon geocoder (included in docker-compose)
ENRICHMENT_PHOTON_BASE_URL=http://photon:2322

EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=data/faiss/index.bin
DEVICE=cpu
CRYSTALLIZER_INTERVAL=300

# Use smaller spaCy model for faster setup (set to en_core_web_trf for better accuracy)
ENRICHMENT_SPACY_MODEL=en_core_web_sm

# LLM extraction (Tier 3 relationship extraction)
ENRICHMENT_LLM_MODEL=claude-sonnet-4-20250514
ENRICHMENT_LLM_HOURLY_CAP_USD=1.00
ENRICHMENT_LLM_DAILY_CAP_USD=5.00
ENRICHMENT_LLM_TIMEOUT_SECONDS=30
ENRICHMENT_LLM_MAX_TOKENS_PER_REQUEST=4000

# Lower cluster size for faster cluster formation with less data
CRYSTALLIZER_MIN_CLUSTER_SIZE=3

# CORS origins (comma-separated, e.g. http://localhost:5173,https://app.example.com)
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,http://localhost:3000
