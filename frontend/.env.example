VITE_API_BASE_URL=http://localhost:8000

# Clerk publishable key (frontend). Find it in the Clerk Dashboard → API Keys.
# When set, the "Sign In" tab + Clerk session auth are enabled. Leave unset to
# fall back to the legacy QR / API-key login only.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mapbox token for map display
VITE_MAPBOX_ACCESS_TOKEN=
